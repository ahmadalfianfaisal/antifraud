{
  "description": "Velocity aggregation per sourceAccount untuk enrichment fraud scoring v3. Window: 2min/5min/1h/1d dari now (refresh tiap 1 menit).",
  "source": {
    "index": ["garda-context-bifast_trx"],
    "query": {
      "range": {
        "@timestamp": { "gte": "now-1d/m" }
      }
    }
  },
  "dest": {
    "index": "acct-velocity-snapshot"
  },
  "frequency": "1m",
  "sync": {
    "time": {
      "field": "@timestamp",
      "delay": "30s"
    }
  },
  "pivot": {
    "group_by": {
      "sourceAccount": {
        "terms": { "field": "sourceAccount.keyword" }
      }
    },
    "aggregations": {
      "amt_sum_2min": {
        "filter": { "range": { "@timestamp": { "gte": "now-2m/m" } } },
        "aggs": { "s": { "sum": { "field": "amount" } } }
      },
      "amt_sum_5min": {
        "filter": { "range": { "@timestamp": { "gte": "now-5m/m" } } },
        "aggs": { "s": { "sum": { "field": "amount" } } }
      },
      "amt_sum_1h": {
        "filter": { "range": { "@timestamp": { "gte": "now-1h/m" } } },
        "aggs": { "s": { "sum": { "field": "amount" } } }
      },
      "amt_sum_1d": {
        "filter": { "range": { "@timestamp": { "gte": "now-1d/m" } } },
        "aggs": { "s": { "sum": { "field": "amount" } } }
      },
      "tx_count_5min": {
        "filter": { "range": { "@timestamp": { "gte": "now-5m/m" } } },
        "aggs": { "c": { "value_count": { "field": "amount" } } }
      },
      "tx_count_1h": {
        "filter": { "range": { "@timestamp": { "gte": "now-1h/m" } } },
        "aggs": { "c": { "value_count": { "field": "amount" } } }
      },
      "distinct_device_5min": {
        "filter": { "range": { "@timestamp": { "gte": "now-5m/m" } } },
        "aggs": { "d": { "cardinality": { "field": "deviceId.keyword" } } }
      },
      "distinct_ip_5min": {
        "filter": { "range": { "@timestamp": { "gte": "now-5m/m" } } },
        "aggs": { "d": { "cardinality": { "field": "ipAddress.keyword" } } }
      },
      "distinct_location_5min": {
        "filter": { "range": { "@timestamp": { "gte": "now-5m/m" } } },
        "aggs": { "d": { "cardinality": { "script": "doc['latitude'].value + '_' + doc['longitude'].value" } } }
      }
    }
  }
}
